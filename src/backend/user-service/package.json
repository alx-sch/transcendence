{
  "name": "user-service",
  "version": "1.0.0",
  "description": "Handles user identity, profiles, and data persistence.",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/index.ts",
    "build": "tsc",
    "start": "NODE_ENV=production node src/dist/index.js",
    "postbuild": "cp -r data dist/data",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^12.4.1",
    "fastify": "^5.6.2",
    "bcryptjs": "^2.4.3",
    "@fastify/formbody": "^8.0.0",
    "@fastify/session": "^11.1.1",
    "@fastify/cookie": "^10.0.0",
    "dotenv": "^16.4.5",
    "pino": "^10.1.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "pino-pretty": "^13.1.2"
  }
}
